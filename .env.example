# PostgreSQL
POSTGRES_USER=burrow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=burrow_dev
DB_HOST=db

# Phoenix Backend
SECRET_KEY_BASE=generate_a_secret_key_here
DATABASE_URL=ecto://burrow:changeme@db/burrow_dev
PHX_HOST=localhost
PORT=4000

# Redis
REDIS_URL=redis://redis:6379

# S3 / MinIO
MINIO_ROOT_USER=burrow
MINIO_ROOT_PASSWORD=replace_with_strong_password
AWS_ACCESS_KEY_ID=burrow
AWS_SECRET_ACCESS_KEY=replace_with_strong_password
AWS_S3_BUCKET=burrow
AWS_S3_PUBLIC_ENDPOINT=http://localhost:9000

# CORS (comma-separated origins for production)
# CORS_ORIGINS=https://app.catxhosting.com

# WebAuthn (defaults to PHX_HOST in production)
# WEBAUTHN_RP_ID=app.catxhosting.com
# WEBAUTHN_ORIGIN=https://app.catxhosting.com

# TURN / STUN (coturn)
TURN_HOST=localhost
TURN_REALM=burrow.local
TURN_SECRET=replace_with_random_hex_secret
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_MIN_PORT=49152
TURN_MAX_PORT=49252

# WebRTC Media Constraints
WEBRTC_AUDIO_CODEC=opus
WEBRTC_VIDEO_DEFAULT_HEIGHT=480
WEBRTC_VIDEO_MAX_HEIGHT=720
WEBRTC_VIDEO_DEFAULT_FPS=24
WEBRTC_VIDEO_MAX_FPS=30
WEBRTC_VIDEO_DEFAULT_BITRATE_KBPS=800
WEBRTC_VIDEO_MAX_BITRATE_KBPS=2500
WEBRTC_AUDIO_BITRATE_KBPS=64

# --- Production-only settings below ---

# TLS 1.3 (when terminating TLS at the app, not behind a reverse proxy)
# SSL_KEY_PATH=/etc/ssl/burrow/server-key.pem
# SSL_CERT_PATH=/etc/ssl/burrow/server-cert.pem
# SSL_CA_PATH=/etc/ssl/burrow/ca.pem

# mTLS for internal services (PostgreSQL, Redis)
# MTLS_ENABLED=true
# MTLS_CA_CERTFILE=/etc/ssl/burrow/ca.pem
# MTLS_CLIENT_CERTFILE=/etc/ssl/burrow/client-cert.pem
# MTLS_CLIENT_KEYFILE=/etc/ssl/burrow/client-key.pem

# PostgreSQL SSL (separate from mTLS)
# DB_SSL=true
# DB_CA_CERTFILE=/etc/ssl/burrow/db-ca.pem
# DB_CLIENT_CERTFILE=/etc/ssl/burrow/db-client-cert.pem
# DB_CLIENT_KEYFILE=/etc/ssl/burrow/db-client-key.pem

# ToS / Privacy Policy version overrides
# TOS_VERSION=1.0
# PRIVACY_VERSION=1.0
